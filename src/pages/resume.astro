---
import MainLayout from "@/layouts/MainLayout.astro";
import PageHeader from "@/components/PageHeader.astro";
import { resumeData, siteConfig } from "@/data/site";
---

<MainLayout
  title="Resume | Connor Pink"
  description="Resume, experience, education, funding, and technical skills for Connor Pink."
>
  <section class="shell pt-10">
    <PageHeader
      kicker="Resume"
      title="Resume"
      intro="Experience, education, awards, and skills."
    />
  </section>

  <section class="shell pt-8">
    <div class="grid gap-6 lg:grid-cols-[1.2fr_0.8fr]">
      <div class="space-y-6">
        <section class="panel p-6 sm:p-8">
          <div class="section-kicker">Profile</div>
          <p class="mt-4 text-[var(--color-muted)]">{resumeData.summary}</p>
        </section>

        <section class="panel p-6 sm:p-8">
          <div class="section-kicker">Experience</div>
          <div class="mt-6 space-y-6">
            {resumeData.experience.map((item) => (
              <div class="border-b border-white/6 pb-6 last:border-b-0 last:pb-0">
                <div class="font-mono text-xs uppercase tracking-[0.18em] text-[var(--color-signal)]">{item.period}</div>
                <h2 class="mt-3 text-xl font-semibold">{item.title}</h2>
                <div class="mt-1 text-sm text-[var(--color-warm)]">{item.company}</div>
                <p class="mt-3 text-sm text-[var(--color-muted)]">{item.description}</p>
              </div>
            ))}
          </div>
        </section>

        <section class="panel p-6 sm:p-8">
          <div class="section-kicker">Education</div>
          <div class="mt-6 space-y-6">
            {resumeData.education.map((item) => (
              <div>
                <div class="font-mono text-xs uppercase tracking-[0.18em] text-[var(--color-signal)]">{item.period}</div>
                <h2 class="mt-3 text-xl font-semibold">{item.title}</h2>
                <div class="mt-1 text-sm text-[var(--color-warm)]">{item.institution}</div>
                <p class="mt-3 text-sm text-[var(--color-muted)]">{item.description}</p>
              </div>
            ))}
          </div>
        </section>

        <section class="panel p-6 sm:p-8">
          <div class="section-kicker">Awards & Funding</div>
          <div class="mt-6 space-y-6">
            {resumeData.awards.map((item) => (
              <div class="border-b border-white/6 pb-6 last:border-b-0 last:pb-0">
                <h2 class="text-xl font-semibold">{item.title}</h2>
                <div class="mt-1 text-sm text-[var(--color-warm)]">{item.detail}</div>
                <p class="mt-3 text-sm text-[var(--color-muted)]">{item.note}</p>
              </div>
            ))}
          </div>
        </section>
      </div>

      <aside class="space-y-6">
        <section class="panel p-6 sm:p-8">
          <div class="section-kicker">Skills</div>
          <div class="mt-5 flex flex-wrap gap-2">
            {resumeData.skills.map((skill) => (
              <span class="tag">{skill}</span>
            ))}
          </div>
        </section>

        <section class="panel p-6 sm:p-8">
          <div class="section-kicker">PDF Resume</div>
          <div class="mt-5 grid gap-3">
            <a
              href={siteConfig.resumeViewerUrl}
              class="rounded-2xl border border-[rgba(255,184,107,0.22)] bg-[rgba(255,184,107,0.08)] px-4 py-4 text-sm text-[var(--color-warm)] hover:bg-[rgba(255,184,107,0.14)]"
            >
              View in Browser
            </a>
            <a
              href={siteConfig.resumePdfPath}
              download="connor-pink-resume.pdf"
              class="inline-flex items-center justify-center gap-2 rounded-2xl border border-[var(--color-line)] bg-black/20 px-4 py-4 text-sm text-white hover:bg-white/5"
            >
              <svg viewBox="0 0 24 24" fill="none" class="h-4 w-4" aria-hidden="true">
                <path d="M12 4v10" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
                <path d="m8 10 4 4 4-4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
                <path d="M5 19h14" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
              </svg>
              <span>Download Resume</span>
            </a>
          </div>
        </section>

        <section class="panel p-6 sm:p-8">
          <div class="section-kicker">Contact</div>
          <div class="mt-5 grid gap-3">
            <a href={`mailto:${siteConfig.email}`} class="rounded-2xl border border-[var(--color-line)] bg-black/20 px-4 py-4 text-sm text-white hover:bg-white/5">
              {siteConfig.email}
            </a>
            <a href="/contact" class="rounded-2xl border border-[var(--color-line)] bg-black/20 px-4 py-4 text-sm text-white hover:bg-white/5">
              Contact Page
            </a>
          </div>
        </section>
      </aside>
    </div>
  </section>
</MainLayout>
