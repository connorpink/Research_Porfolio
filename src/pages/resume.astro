---
import { Image } from "astro:assets";
import MainLayout from "@/layouts/MainLayout.astro";
import PageHeader from "@/components/PageHeader.astro";
import { resumeData, siteConfig } from "@/data/site";
import portraitImage from "@/assets/images/ConnorPink-1.jpeg";
---

<MainLayout
  title="Resume | Connor Pink"
  description="Resume, experience, education, funding, and technical skills for Connor Pink."
>
  <section class="shell pt-10">
    <div class="grid gap-6 lg:grid-cols-[1.08fr_0.92fr] lg:items-stretch">
      <PageHeader
        kicker="Resume"
        title="Resume"
        intro="Experience, education, awards, and skills."
      />
      <div class="image-frame panel craft-card portrait-side-card mx-auto w-full max-w-sm lg:mx-0 lg:justify-self-end">
        <Image
          src={portraitImage}
          alt="Portrait of Connor Pink."
          widths={[480, 720, 960]}
          sizes="(max-width: 1024px) min(100vw - 2.5rem, 28rem), 28rem"
          class="interactive-media portrait-side-image h-full w-full object-cover object-center"
        />
      </div>
    </div>
  </section>

  <section class="shell pt-8">
    <div class="grid gap-6 lg:grid-cols-[1.2fr_0.8fr]">
      <div class="space-y-6">
        <section class="panel craft-card p-6 sm:p-8">
          <div class="section-kicker">Profile</div>
          <p class="mt-4 text-[var(--color-body)]">{resumeData.summary}</p>
        </section>

        <section class="panel craft-card p-6 sm:p-8">
          <div class="section-kicker">Experience</div>
          <div class="mt-6 space-y-6">
            {resumeData.experience.map((item) => (
              <div class="border-b pb-6 last:border-b-0 last:pb-0" style="border-color: var(--color-line);">
                <div class="measure-label text-[var(--color-accent)]">{item.period}</div>
                <h2 class="mt-3 text-xl font-semibold">{item.title}</h2>
                <div class="mt-1 text-sm text-[var(--color-accent)]">{item.company}</div>
                <p class="mt-3 text-sm text-[var(--color-body)]">{item.description}</p>
              </div>
            ))}
          </div>
        </section>

        <section class="panel craft-card p-6 sm:p-8">
          <div class="section-kicker">Education</div>
          <div class="mt-6 space-y-6">
            {resumeData.education.map((item) => (
              <div>
                <div class="measure-label text-[var(--color-accent)]">{item.period}</div>
                <h2 class="mt-3 text-xl font-semibold">{item.title}</h2>
                <div class="mt-1 text-sm text-[var(--color-accent)]">{item.institution}</div>
                <p class="mt-3 text-sm text-[var(--color-body)]">{item.description}</p>
              </div>
            ))}
          </div>
        </section>

        <section class="panel craft-card p-6 sm:p-8">
          <div class="section-kicker">Awards & Funding</div>
          <div class="mt-6 space-y-6">
            {resumeData.awards.map((item) => (
              <div class="border-b pb-6 last:border-b-0 last:pb-0" style="border-color: var(--color-line);">
                <h2 class="text-xl font-semibold">{item.title}</h2>
                <div class="mt-1 text-sm text-[var(--color-accent)]">{item.detail}</div>
                <p class="mt-3 text-sm text-[var(--color-body)]">{item.note}</p>
              </div>
            ))}
          </div>
        </section>
      </div>

      <aside class="space-y-6">
        <section class="panel craft-card p-6 sm:p-8">
          <div class="section-kicker">Skills</div>
          <div class="mt-5 flex flex-wrap gap-2">
            {resumeData.skills.map((skill) => (
              <span class="tag">{skill}</span>
            ))}
          </div>
        </section>

        <section class="panel craft-card p-6 sm:p-8">
          <div class="section-kicker">PDF Resume</div>
          <div class="mt-5 grid gap-3">
            <a
              href={siteConfig.resumeViewerUrl}
              class="button-primary rounded-[1.25rem] px-4 py-4"
            >
              View in Browser
            </a>
            <a
              href={siteConfig.resumePdfPath}
              download="connor-pink-resume.pdf"
              class="button-secondary inline-flex items-center justify-center gap-2 rounded-[1.25rem] px-4 py-4"
            >
              <svg viewBox="0 0 24 24" fill="none" class="h-4 w-4" aria-hidden="true">
                <path d="M12 4v10" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
                <path d="m8 10 4 4 4-4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
                <path d="M5 19h14" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
              </svg>
              <span>Download Resume</span>
            </a>
          </div>
        </section>

        <section class="panel craft-card p-6 sm:p-8">
          <div class="section-kicker">Contact</div>
          <div class="mt-5 grid gap-3">
            <a href={`mailto:${siteConfig.email}`} class="button-secondary rounded-[1.25rem] px-4 py-4 text-left">
              {siteConfig.email}
            </a>
            <a href="/contact" class="button-secondary rounded-[1.25rem] px-4 py-4 text-left">
              Contact Page
            </a>
          </div>
        </section>
      </aside>
    </div>
  </section>
</MainLayout>
