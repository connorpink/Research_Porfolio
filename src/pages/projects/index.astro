---
import MainLayout from "@/layouts/MainLayout.astro";
import PageHeader from "@/components/PageHeader.astro";
import ProjectCard from "@/components/ProjectCard.astro";
import { getProjects } from "@/lib/content";

const projects = await getProjects();
---

<MainLayout
  title="Projects | Connor Pink"
  description="Selected software engineering projects, internal tooling by Connor Pink."
  showContactFooter={true}
>
  <section class="shell pt-10">
    <PageHeader
      kicker="Projects"
      title="Selected software, interface, and tooling work."
      intro="A compact archive of shipped builds, internal utilities, and experiments worth documenting."
    />
  </section>

  <section class="shell pt-8">
    <div class="section-surface section-surface--grid">
      <div class="grid gap-6 lg:grid-cols-2">
      {
        projects.map((project, index) => (
          <ProjectCard
            href={`/projects/${project.slug}`}
            title={project.data.title}
            summary={project.data.summary}
            year={project.data.year}
            role={project.data.role}
            status={project.data.status}
            stack={project.data.stack}
            cardImage={project.data.cardImage}
            links={project.data.links}
            variant={index === 0 ? "feature" : "standard"}
            reverse={index === 0}
          />
        ))
      }
      </div>
    </div>
  </section>
</MainLayout>
