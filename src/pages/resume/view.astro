---
import MainLayout from "@/layouts/MainLayout.astro";
import { siteConfig } from "@/data/site";
---

<MainLayout title="Resume Viewer | Connor Pink" showContactFooter={false}>
  <section class="shell pt-10">
    <div class="panel craft-card overflow-hidden px-6 py-8 sm:px-10">
      <div
        class="flex flex-col gap-5 md:flex-row md:items-end md:justify-between"
      >
        <div>
          <div class="section-kicker">Resume PDF</div>
          <h1 class="display-title mt-4 text-5xl sm:text-6xl">My Resume</h1>
          <p class="mt-4 max-w-2xl text-[var(--color-body)]">
            The browser preview is available below, with direct open and
            download options if you prefer the file on its own.
          </p>
        </div>
        <div class="flex flex-wrap gap-3">
          <a
            href={siteConfig.resumePdfPath}
            target="_blank"
            rel="noreferrer"
            class="button-primary"
          >
            Open PDF
          </a>
          <a
            href={siteConfig.resumePdfPath}
            download="connor-pink-resume.pdf"
            class="button-secondary"
          >
            Download
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="shell pt-8">
    <div class="panel craft-card overflow-hidden p-2 sm:p-3">
      <iframe
        src={siteConfig.resumePdfPath}
        title="Connor Pink resume PDF"
        class="h-[78vh] w-full rounded-[1.25rem] bg-white"></iframe>
    </div>
  </section>
</MainLayout>
