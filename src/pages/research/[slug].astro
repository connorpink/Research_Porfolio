---
import { getCollection, render } from "astro:content";
import EntryLayout from "@/layouts/EntryLayout.astro";

export async function getStaticPaths() {
  const research = await getCollection("research");
  return research.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<EntryLayout
  title={entry.data.title}
  kicker="Research Note"
  summary={entry.data.summary}
  pageImage={entry.data.pageImage}
  actions={[
    { label: "Research Page", href: `/research/${entry.slug}` },
    ...(entry.data.links?.repo ? [{ label: "GitHub", href: entry.data.links.repo, external: true, tone: "secondary" as const }] : []),
    ...(entry.data.links?.live ? [{ label: "Live", href: entry.data.links.live, external: true, tone: "secondary" as const }] : []),
  ]}
  meta={[
    { label: "Year", value: entry.data.year },
    { label: "Domain", value: entry.data.domain },
    { label: "Publication", value: entry.data.publication },
    { label: "Tags", value: entry.data.tags.join(", ") },
  ]}
>
  <Content />
</EntryLayout>
