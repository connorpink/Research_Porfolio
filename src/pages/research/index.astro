---
import MainLayout from "@/layouts/MainLayout.astro";
import PageHeader from "@/components/PageHeader.astro";
import ResearchCard from "@/components/ResearchCard.astro";
import { getResearch } from "@/lib/content";

const research = await getResearch();
---

<MainLayout
  title="Research | Connor Pink"
  description="Research notes and technical case studies on AI, healthcare imaging, debugging systems, and interface design."
>
  <section class="shell pt-10">
    <PageHeader
      kicker="Research"
      title="Long-form analysis organized as static case studies."
      intro="Heres some of the Research Projects I've been apart of during my Studies."
    />
  </section>

  <section class="shell pt-8">
    <div class="grid gap-6 lg:grid-cols-2">
      {
        research.map((entry) => (
          <ResearchCard
            href={`/research/${entry.slug}`}
            title={entry.data.title}
            summary={entry.data.summary}
            year={entry.data.year}
            domain={entry.data.domain}
            publication={entry.data.publication}
            tags={entry.data.tags}
            cardImage={entry.data.cardImage}
            links={entry.data.links}
          />
        ))
      }
    </div>
  </section>
</MainLayout>
