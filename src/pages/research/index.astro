---
import MainLayout from "@/layouts/MainLayout.astro";
import PageHeader from "@/components/PageHeader.astro";
import ResearchCard from "@/components/ResearchCard.astro";
import { getResearch } from "@/lib/content";

const research = await getResearch();
---

<MainLayout
  title="Research | Connor Pink"
  description="Research notes and technical case studies on AI, healthcare imaging, debugging systems, and interface design."
  showContactFooter={true}
>
  <section class="shell pt-10">
    <PageHeader
      kicker="Research"
      title="Research notes organized as focused case studies."
      intro="Methods, figures, and outcomes from graduate work in medical imaging, evaluation, and applied machine learning."
    />
  </section>

  <section class="shell pt-8">
    <div class="section-surface">
      <div class="space-y-6">
      {
        research.map((entry, index) => (
          <ResearchCard
            href={`/research/${entry.slug}`}
            title={entry.data.title}
            summary={entry.data.summary}
            year={entry.data.year}
            domain={entry.data.domain}
            publication={entry.data.publication}
            tags={entry.data.tags}
            cardImage={entry.data.cardImage}
            links={entry.data.links}
            reverse={index % 2 === 1}
          />
        ))
      }
      </div>
    </div>
  </section>
</MainLayout>
