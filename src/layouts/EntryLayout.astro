---
import { Image } from "astro:assets";
import MainLayout from "@/layouts/MainLayout.astro";

interface Props {
  title: string;
  kicker: string;
  summary: string;
  meta: { label: string; value: string }[];
  pageImage?: ImageMetadata;
  actions?: { label: string; href: string; external?: boolean; tone?: "primary" | "secondary" }[];
}

const { title, kicker, summary, meta, pageImage, actions = [] } = Astro.props;
---

<MainLayout
  title={title}
  description={summary}
  image={pageImage?.src}
  imageAlt={title}
  imageWidth={pageImage?.width}
  imageHeight={pageImage?.height}
  type="article"
  showContactFooter={true}
>
  <section class="shell pt-10">
    <div class="panel craft-card overflow-hidden px-6 py-10 sm:px-10">
      <div class="grid gap-8 lg:grid-cols-[0.92fr_1.08fr] lg:items-start">
        <div>
          <div class="section-kicker">{kicker}</div>
          <h1 class="display-title mt-4 max-w-4xl text-5xl sm:text-6xl">{title}</h1>
          <p class="mt-5 max-w-2xl text-base text-[var(--color-body)] sm:text-lg">{summary}</p>
          <div class="section-divider max-w-2xl"></div>
          <div class="mt-8 grid gap-4 sm:grid-cols-2">
            {meta.map((item) => (
              <div class="meta-card">
                <div class="measure-label">
                  {item.label}
                </div>
                <div class="mt-2 text-sm text-[var(--color-text)]">{item.value}</div>
              </div>
            ))}
          </div>
          {actions.length > 0 && (
            <div class="mt-6 flex flex-wrap gap-3">
              {actions.map((action) => (
                <a
                  href={action.href}
                  target={action.external ? "_blank" : undefined}
                  rel={action.external ? "noreferrer" : undefined}
                  class:list={[
                    action.tone === "secondary" ? "button-secondary" : "button-primary",
                  ]}
                >
                  {action.label}
                </a>
              ))}
            </div>
          )}
        </div>
        {pageImage && (
          <div class="image-frame">
            <Image
              src={pageImage}
              alt={title}
              widths={[640, 960, 1280, 1600]}
              sizes="(max-width: 1280px) 100vw, 54vw"
              class="max-h-[38rem] w-full object-cover"
            />
          </div>
        )}
      </div>
    </div>
  </section>
  <section class="shell pt-8">
    <article class="panel craft-card prose-case px-6 py-8 sm:px-10 sm:py-10">
      <slot />
    </article>
  </section>
</MainLayout>
