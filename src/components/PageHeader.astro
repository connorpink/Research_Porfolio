---
interface Props {
  kicker: string;
  title: string;
  intro: string;
}

const { kicker, title, intro } = Astro.props;
---

<header class="panel craft-card overflow-hidden px-6 py-10 sm:px-10">
  <div class="section-kicker">{kicker}</div>
  <h1 class="display-title mt-4 max-w-3xl text-5xl sm:text-6xl">{title}</h1>
  <p class="mt-5 max-w-2xl text-base text-[var(--color-body)] sm:text-lg">{intro}</p>
  <div class="section-divider"></div>
</header>
