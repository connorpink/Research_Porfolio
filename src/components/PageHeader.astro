---
interface Props {
  kicker: string;
  title: string;
  intro: string;
}

const { kicker, title, intro } = Astro.props;
---

<header class="panel grid-overlay overflow-hidden px-6 py-10 sm:px-10">
  <div class="section-kicker">{kicker}</div>
  <h1 class="mt-4 max-w-3xl text-4xl font-semibold sm:text-5xl">{title}</h1>
  <p class="mt-5 max-w-2xl text-base text-[var(--color-muted)] sm:text-lg">{intro}</p>
</header>
