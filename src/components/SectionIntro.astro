---
interface Props {
  kicker: string;
  title: string;
  text: string;
  href?: string;
  linkLabel?: string;
}

const { kicker, title, text, href, linkLabel } = Astro.props;
---

<div class="flex flex-col items-start justify-between gap-6 md:flex-row md:items-end">
  <div class="max-w-2xl">
    <div class="section-kicker">{kicker}</div>
    <h2 class="section-title mt-4">{title}</h2>
    <p class="mt-4 text-[var(--color-muted)]">{text}</p>
  </div>
  {href && linkLabel && (
    <a
      href={href}
      class="rounded-full border border-[var(--color-line-strong)] px-5 py-3 font-mono text-xs uppercase tracking-[0.2em] text-white hover:bg-white/5"
    >
      {linkLabel}
    </a>
  )}
</div>
