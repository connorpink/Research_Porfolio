---
import { Image } from "astro:assets";

interface Props {
  href: string;
  title: string;
  summary: string;
  year: string;
  domain: string;
  publication: string;
  tags: string[];
  cardImage?: ImageMetadata;
  links?: {
    live?: string;
    repo?: string;
  };
  reverse?: boolean;
}

const {
  href,
  title,
  summary,
  year,
  domain,
  publication,
  tags,
  cardImage,
  links,
  reverse = false,
} = Astro.props;
---

<article class="panel craft-card interactive-card overflow-hidden">
  <div class="grid gap-0 lg:grid-cols-[0.92fr_1.08fr]">
    {cardImage && (
      <div
        class:list={[
          "border-b p-4 lg:border-b-0 lg:border-r",
          reverse && "lg:order-2 lg:border-r-0 lg:border-l",
        ]}
        style="border-color: var(--color-line); background: rgba(255, 255, 255, 0.03);"
      >
        <div class="image-frame h-full">
          <Image
            src={cardImage}
            alt={title}
            widths={[480, 720, 960]}
            sizes="(max-width: 1024px) 100vw, 40vw"
            class="interactive-media h-full min-h-[18rem] w-full object-contain object-center p-5"
          />
        </div>
      </div>
    )}

    <div class:list={["flex flex-col justify-between p-6 sm:p-8", reverse && "lg:order-1"]}>
      <div>
        <div class="flex flex-wrap items-center gap-3">
          <span class="section-kicker">{year}</span>
          <span class="tag">{domain}</span>
        </div>
        <a href={href} class="mt-5 block max-w-2xl text-4xl text-[var(--color-text)] hover:text-[var(--color-accent)]">
          {title}
        </a>
        <p class="mt-5 max-w-2xl text-base">{summary}</p>
      </div>

      <div class="mt-8 space-y-6">
        <div class="grid gap-4 sm:grid-cols-[0.95fr_1.05fr]">
          <div class="meta-card">
            <div class="measure-label">Publication</div>
            <div class="mt-2 text-sm text-[var(--color-text)]">{publication}</div>
          </div>
          <div class="meta-card">
            <div class="measure-label">Keywords</div>
            <div class="mt-2 flex flex-wrap gap-2">
              {tags.map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          </div>
        </div>
        <div class="flex flex-wrap gap-3">
          <a href={href} class="button-primary">Read Summary</a>
          {links?.repo && (
            <a href={links.repo} target="_blank" rel="noreferrer" class="button-secondary">
              GitHub
            </a>
          )}
          {links?.live && (
            <a href={links.live} target="_blank" rel="noreferrer" class="button-secondary">
              Live
            </a>
          )}
        </div>
      </div>
    </div>
  </div>
</article>
