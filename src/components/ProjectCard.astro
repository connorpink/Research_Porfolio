---
import { Image } from "astro:assets";

interface Props {
  href: string;
  title: string;
  summary: string;
  year: string;
  role: string;
  status: string;
  stack: string[];
  cardImage?: ImageMetadata;
  links?: {
    live?: string;
    repo?: string;
  };
  variant?: "feature" | "standard";
  reverse?: boolean;
}

const {
  href,
  title,
  summary,
  year,
  role,
  status,
  stack,
  cardImage,
  links,
  variant = "standard",
  reverse = false,
} = Astro.props;

const isFeature = variant === "feature";
---

{
  isFeature ? (
    <article class="panel craft-card interactive-card overflow-hidden lg:col-span-2">
      <div class="grid gap-0 lg:grid-cols-[1.02fr_0.98fr]">
        <div
          class:list={[
            "flex flex-col justify-between p-6 sm:p-8",
            reverse && "lg:order-2",
          ]}
        >
          <div>
            <div class="flex items-center justify-between gap-4">
              <div class="section-kicker">{year} / Featured Project</div>
              <div class="measure-label text-[var(--color-accent)]">
                {status}
              </div>
            </div>
            <h3 class="mt-5 max-w-2xl text-4xl sm:text-5xl">{title}</h3>
            <p class="mt-5 max-w-2xl text-base sm:text-lg">{summary}</p>
          </div>

          <div class="mt-8 space-y-6">
            <div class="grid gap-4 sm:grid-cols-[0.9fr_1.1fr]">
              <div class="meta-card">
                <div class="measure-label">Role</div>
                <div class="mt-2 text-sm text-[var(--color-text)]">{role}</div>
              </div>
              <div class="meta-card">
                <div class="measure-label">Stack</div>
                <div class="mt-2 flex flex-wrap gap-2">
                  {stack.slice(0, 5).map((item) => (
                    <span class="tag">{item}</span>
                  ))}
                </div>
              </div>
            </div>
            <div class="flex flex-wrap gap-3">
              <a href={href} class="button-primary">
                See more
              </a>
              {links?.repo && (
                <a
                  href={links.repo}
                  target="_blank"
                  rel="noreferrer"
                  class="button-secondary"
                >
                  GitHub
                </a>
              )}
              {links?.live && (
                <a
                  href={links.live}
                  target="_blank"
                  rel="noreferrer"
                  class="button-secondary"
                >
                  Live
                </a>
              )}
            </div>
          </div>
        </div>

        {cardImage && (
          <div
            class:list={[
              "border-t p-4 lg:border-t-0 lg:border-l",
              reverse ? "lg:order-1 lg:border-l-0 lg:border-r" : "",
            ]}
            style="border-color: var(--color-line); background: rgba(255, 255, 255, 0.03);"
          >
            <div class="image-frame h-full">
              <Image
                src={cardImage}
                alt={title}
                widths={[480, 720, 960]}
                sizes="(max-width: 1024px) 100vw, 48vw"
                class="interactive-media h-full min-h-[20rem] w-full object-contain object-center p-5"
              />
            </div>
          </div>
        )}
      </div>
    </article>
  ) : (
    <article class="panel craft-card interactive-card flex h-full flex-col overflow-hidden">
      {cardImage && (
        <div
          class="border-b p-4"
          style="border-color: var(--color-line); background: rgba(255, 255, 255, 0.03);"
        >
          <div class="image-frame">
            <Image
              src={cardImage}
              alt={title}
              widths={[320, 480, 640]}
              sizes="(max-width: 1024px) 100vw, 50vw"
              class="interactive-media h-52 w-full object-contain object-center p-4"
            />
          </div>
        </div>
      )}
      <div class="flex h-full flex-col p-6">
        <div class="flex items-center justify-between gap-4">
          <div class="measure-label">{year}</div>
          <div class="measure-label text-[var(--color-accent)]">{status}</div>
        </div>
        <a
          href={href}
          class="mt-4 block text-3xl text-[var(--color-text)] hover:text-[var(--color-accent)]"
        >
          {title}
        </a>
        <p class="mt-4 flex-1 text-sm">{summary}</p>
        <div class="meta-card mt-6">
          <div class="measure-label">Role</div>
          <div class="mt-2 text-sm text-[var(--color-text)]">{role}</div>
        </div>
        <div class="mt-5 flex flex-wrap gap-2">
          {stack.map((item) => (
            <span class="tag">{item}</span>
          ))}
        </div>
        <div class="mt-6 flex flex-wrap gap-3">
          <a href={href} class="button-primary !px-4 !py-2">
            Open
          </a>
          {links?.repo && (
            <a
              href={links.repo}
              target="_blank"
              rel="noreferrer"
              class="button-secondary !px-4 !py-2"
            >
              GitHub
            </a>
          )}
          {links?.live && (
            <a
              href={links.live}
              target="_blank"
              rel="noreferrer"
              class="button-secondary !px-4 !py-2"
            >
              Live
            </a>
          )}
        </div>
      </div>
    </article>
  )
}
